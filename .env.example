# ── Upstox API credentials ─────────────────────────────────────────────
# Create an app at https://account.upstox.com/developer/apps to obtain these.
# Copy this file to .env (in this server folder) and fill in the values.
# Until set, the backend serves realistic MOCK / replay data so the app is
# fully demoable without an Upstox account.

# From your Upstox developer app:
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# Must EXACTLY match the redirect URI registered on your Upstox app.
# The backend's OAuth callback is at /auth/callback :
UPSTOX_REDIRECT_URI=http://localhost:8000/auth/callback

# Optional: use Upstox sandbox for testing (true/false).
UPSTOX_SANDBOX=false

# Backend port + the frontend origin (for CORS / post-login redirect).
PORT=8000
CLIENT_URL=http://localhost:5173
